# Auto-detect text files and normalize to LF in the repo.
* text=auto eol=lf

# Explicit LF for all source and text formats.
*.java       text eol=lf
*.kt         text eol=lf
*.gradle     text eol=lf
*.properties text eol=lf
*.json       text eol=lf
*.json5      text eol=lf
*.md         text eol=lf
*.txt        text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.toml       text eol=lf
*.xml        text eol=lf
*.cfg        text eol=lf

# Shell / build scripts
gradlew      text eol=lf
*.sh         text eol=lf

# Windows-only scripts keep CRLF.
*.bat        text eol=crlf
*.cmd        text eol=crlf

# Binary assets — never touch.
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
*.webp       binary
*.jar        binary
*.zip        binary
*.gz         binary
*.nbt        binary
