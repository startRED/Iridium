{
  "schemaVersion": 1,
  "id": "iridium",
  "version": "${version}",
  "name": "Iridium",
  "description": "A companion to Sodium and Lithium: entity, particle, block-entity culling and server-side throttles.",
  "authors": [
    "startRED"
  ],
  "license": "LicenseRef-PolyForm-Shield-1.0.0",
  "icon": "assets/iridium/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.iridium.Iridium"
    ],
    "client": [
      "com.iridium.IridiumClient"
    ],
    "modmenu": [
      "com.iridium.config.IridiumConfigScreen"
    ]
  },
  "mixins": [
    "iridium.mixins.json",
    {
      "config": "iridium.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.15.11",
    "fabric-api": ">=0.102.0",
    "minecraft": "1.21.1",
    "java": ">=21"
